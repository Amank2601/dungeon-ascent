# ─── Server ───────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/dungeon_ascent
# Atlas (replace with your connection string):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/dungeon_ascent

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# ─── Client ───────────────────────────────────────
CLIENT_URL=http://localhost:3000
